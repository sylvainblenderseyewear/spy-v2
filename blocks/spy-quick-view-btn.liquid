{%- if closest.product -%}
<button
  class="block w-full py-2 px-3 bg-transparent border border-spy-border text-spy-slate text-[11px] font-bold uppercase tracking-widest cursor-pointer text-center mt-1.5 transition-colors hover:bg-spy-slate hover:text-white hover:border-spy-slate"
  data-spy-qv="{{ closest.product.handle }}"
  aria-label="Quick View {{ closest.product.title | escape }}"
  type="button"
  {{ block.shopify_attributes }}
>Quick View</button>
{%- endif -%}

{% schema %}
{
  "name": "Quick View Button",
  "tag": null,
  "settings": [],
  "presets": [
    {
      "name": "Quick View Button",
      "category": "SPY"
    }
  ]
}
{% endschema %}
