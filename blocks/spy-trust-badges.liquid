{%- liquid
  assign badge_count = 0
  for i in (1..5)
    assign text_key = 'badge_' | append: i | append: '_text'
    if block.settings[text_key] != blank
      assign badge_count = badge_count | plus: 1
    endif
  endfor
-%}

{%- if badge_count > 0 -%}
<div class="border border-spy-border p-3 mt-8 text-[color:var(--color-spy-text-2)]" {{ block.shopify_attributes }}>
  {%- for i in (1..5) -%}
    {%- liquid
      assign text_key = 'badge_' | append: i | append: '_text'
      assign icon_key = 'badge_' | append: i | append: '_icon'
      assign badge_text = block.settings[text_key]
      assign badge_icon = block.settings[icon_key]
    -%}
    {%- if badge_text != blank -%}
      <div class="flex items-center gap-3 py-2 border-b border-spy-border last:border-b-0">
        <span class="shrink-0 w-5 h-5 flex items-center justify-center leading-[0] text-[color:var(--color-foreground,#2c393e)]" aria-hidden="true">
          {%- if badge_icon != blank -%}
            {{ badge_icon }}
          {%- else -%}
            {%- case i -%}
              {%- when 1 -%}
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M1 13h1m13 0h2M3 13V8l2-3h7l3 3.5V13M3 13h10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="5.5" cy="14.5" r="1.5" stroke="currentColor" stroke-width="1.2"/><circle cx="12.5" cy="14.5" r="1.5" stroke="currentColor" stroke-width="1.2"/><path d="M3 8h11" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              {%- when 2 -%}
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3.5 9A5.5 5.5 0 1 0 9 3.5H4m0 0 2.5 2.5M4 3.5 6.5 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {%- when 3 -%}
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 1.5 3 4v5.5C3 13 5.5 15.5 9 16.5c3.5-1 6-3.5 6-7V4L9 1.5Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><path d="m6.5 9 2 2 3-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {%- when 4 -%}
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="2" y="5" width="14" height="10" rx="1.5" stroke="currentColor" stroke-width="1.2"/><path d="M2 8.5h14" stroke="currentColor" stroke-width="1.2"/><path d="M5 12h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              {%- when 5 -%}
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2l1.6 3.3 3.6.5-2.6 2.5.6 3.6L9 10.2l-3.2 1.7.6-3.6L3.8 5.8l3.6-.5L9 2Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg>
            {%- endcase -%}
          {%- endif -%}
        </span>
        <span class="text-xs font-medium leading-[1.4] text-[color:var(--color-foreground,#2c393e)]">{{ badge_text }}</span>
      </div>
    {%- endif -%}
  {%- endfor -%}
</div>
{%- endif -%}

