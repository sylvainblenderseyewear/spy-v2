{% doc %}
  Image cards for one mega-menu dropdown. Addable block: set "Menu item" to the
  top-level menu title, add up to 4 images. The cards render inside this block
  (its own settings are readable) and a small script places them into the
  matching dropdown panel's reserved image zone.
{% enddoc %}

{% liquid
  assign target_handle = block.settings.menu_item | handleize
%}

<div
  class="contents"
  data-menu-promo="{{ target_handle }}"
  hidden
  {{ block.shopify_attributes }}
>
  {% for i in (1..4) %}
    {% liquid
      assign image_key = 'image_' | append: i
      assign caption_key = 'caption_' | append: i
      assign link_key = 'link_' | append: i
      assign card_image = block.settings[image_key]
      assign card_caption = block.settings[caption_key]
      assign card_link = block.settings[link_key]
    %}
    {% if card_image %}
      <a href="{{ card_link | default: '#' }}" class="block no-underline">
        {{ card_image | image_url: width: 600 | image_tag: class: 'w-full aspect-[41/32] object-cover', loading: 'lazy' }}
        {% if card_caption != blank %}
          <span class="block mt-2 text-center text-[12px] font-bold uppercase tracking-[0.06em] text-spy-ink">{{ card_caption }}</span>
        {% endif %}
      </a>
    {% endif %}
  {% endfor %}
</div>
<script>
  (() => {
    const el = document.currentScript.previousElementSibling;
    const place = () => {
      const slot = document.querySelector('[data-promo-slot="' + el.dataset.menuPromo + '"]');
      const mobileSlot = document.querySelector('[data-promo-slot-mobile="' + el.dataset.menuPromo + '"]');

      if (mobileSlot && !mobileSlot.querySelector('a')) {
        const firstLink = el.querySelector('a');
        if (firstLink) {
          const copy = el.cloneNode(false);
          copy.removeAttribute('data-shopify-editor-block');
          copy.hidden = false;
          copy.appendChild(firstLink.cloneNode(true));
          mobileSlot.appendChild(copy);
        }
      }
      if (slot) {
        slot.appendChild(el);
        el.hidden = false;
      }
    };
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', place, { once: true });
    } else {
      place();
    }
    document.currentScript.remove();
  })();
</script>

{% schema %}
{
  "name": "Menu images",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "menu_item",
      "label": "Menu item",
      "info": "Exact title of the top-level menu item these images belong to (e.g. Sunglasses)"
    },
    {
      "type": "header",
      "content": "Image 1"
    },
    { "type": "image_picker", "id": "image_1", "label": "Image" },
    { "type": "text", "id": "caption_1", "label": "Caption" },
    { "type": "url", "id": "link_1", "label": "Link" },
    {
      "type": "header",
      "content": "Image 2"
    },
    { "type": "image_picker", "id": "image_2", "label": "Image" },
    { "type": "text", "id": "caption_2", "label": "Caption" },
    { "type": "url", "id": "link_2", "label": "Link" },
    {
      "type": "header",
      "content": "Image 3"
    },
    { "type": "image_picker", "id": "image_3", "label": "Image" },
    { "type": "text", "id": "caption_3", "label": "Caption" },
    { "type": "url", "id": "link_3", "label": "Link" },
    {
      "type": "header",
      "content": "Image 4"
    },
    { "type": "image_picker", "id": "image_4", "label": "Image" },
    { "type": "text", "id": "caption_4", "label": "Caption" },
    { "type": "url", "id": "link_4", "label": "Link" }
  ],
  "presets": [
    {
      "name": "Menu images"
    }
  ]
}
{% endschema %}
