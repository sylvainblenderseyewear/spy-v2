{%- liquid
  assign p = closest.product
  assign size_chart_ref = p.metafields.pdp.size_chart.value
-%}

{%- if size_chart_ref != blank or block.settings.fallback_label != blank -%}
<div class="spy-size-chart py-1" {{ block.shopify_attributes }}>
  {%- liquid
    if size_chart_ref != blank
      assign chart_image = size_chart_ref.fields.image.value
      assign chart_name  = size_chart_ref.fields.name.value
      if chart_name == blank
        assign chart_name = block.settings.fallback_label
      endif
    else
      assign chart_name = block.settings.fallback_label
    endif
  -%}

  <button
    type="button"
    class="inline-flex items-center gap-1.5 bg-transparent border-none p-0 cursor-pointer text-[12px] font-bold uppercase tracking-[0.06em] underline underline-offset-[3px] text-[color:var(--color-foreground,#2c393e)] hover:text-spy-orange"
    aria-haspopup="dialog"
    data-spy-size-chart-open
  >
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <rect x="1" y="4" width="14" height="8" rx="1" stroke="currentColor" stroke-width="1.2"/>
      <path d="M4 4V3m4 1V3m4 1V3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    </svg>
    <span>{{ chart_name | default: 'Size Chart' }}</span>
  </button>

  {%- if size_chart_ref != blank and chart_image != blank -%}
  <div
    class="hidden fixed inset-0 z-[1001] data-[open]:block"
    role="dialog"
    aria-modal="true"
    aria-label="{{ chart_name | escape }}"
    aria-hidden="true"
    data-spy-size-chart-modal
  >
    <div class="absolute inset-0 bg-black/55" data-spy-size-chart-close></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-white w-[min(560px,95vw)] max-h-[90vh] overflow-y-auto pt-10 px-7 pb-7 max-[750px]:top-auto max-[750px]:bottom-0 max-[750px]:left-0 max-[750px]:translate-x-0 max-[750px]:translate-y-0 max-[750px]:w-full max-[750px]:rounded-t-xl max-[750px]:px-5 max-[750px]:pb-8">
      <button type="button" class="absolute top-3 right-3 bg-transparent border-none cursor-pointer p-1.5 flex items-center text-[color:var(--color-foreground,#2c393e)] hover:text-spy-orange" aria-label="Close size chart" data-spy-size-chart-close>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M15 5L5 15M5 5l10 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
      <p class="text-[14px] font-bold uppercase tracking-[0.06em] m-0 mb-4 text-[color:var(--color-foreground,#2c393e)]">{{ chart_name }}</p>
      <img
        src="{{ chart_image | image_url: width: 800 }}"
        alt="{{ chart_name | escape }}"
        width="800"
        height="800"
        loading="lazy"
        class="w-full h-auto block"
      >
    </div>
  </div>
  {%- endif -%}
</div>
{%- endif -%}

<script>
  (() => {
    const wrap = document.currentScript.closest('.spy-size-chart');
    if (!wrap) return;
    const trigger = wrap.querySelector('[data-spy-size-chart-open]');
    const modal   = wrap.querySelector('[data-spy-size-chart-modal]');
    if (!trigger || !modal) return;
    const open  = () => { modal.setAttribute('aria-hidden', 'false'); modal.dataset.open = ''; document.body.style.overflow = 'hidden'; };
    const close = () => { modal.setAttribute('aria-hidden', 'true');  delete modal.dataset.open;  document.body.style.overflow = ''; };
    trigger.addEventListener('click', open);
    wrap.querySelectorAll('[data-spy-size-chart-close]').forEach(el => el.addEventListener('click', close));
    document.addEventListener('keydown', e => { if (e.key === 'Escape' && modal.dataset.open !== undefined) close(); });
  })();
</script>

{% schema %}
{
  "name": "Size Chart",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "fallback_label",
      "label": "Button label (fallback)",
      "default": "Size Chart"
    }
  ],
  "presets": [
    {
      "name": "Size Chart",
      "category": "SPY"
    }
  ]
}
{% endschema %}
