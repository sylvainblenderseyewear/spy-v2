{% liquid
  assign menu = block.settings.menu
  assign highlight_handle = block.settings.highlight_item | handleize
%}

<nav
  class="spy-mega-menu flex items-center self-stretch max-md:order-first md:flex-1 md:justify-center"
  aria-label="{{ 'accessibility.header_navigation_label' | t }}"
  {{ block.shopify_attributes }}
>
  <ul class="hidden md:flex items-stretch h-full gap-4 lg:gap-8 list-none m-0 p-0">
    {% for link in menu.links %}
      {% liquid
        assign link_handle = link.title | handleize
        assign is_highlight = false
        if link_handle == highlight_handle and highlight_handle != blank
          assign is_highlight = true
        endif
      %}
      <li class="group flex items-stretch">
        <a
          href="{{ link.url }}"
          class="inline-flex items-center h-full px-3 lg:px-4 border-b-2 border-transparent group-hover:border-black text-[14px] font-bold uppercase tracking-[0.5px] no-underline whitespace-nowrap transition-colors duration-200 {% if is_highlight %}text-spy-orange{% else %}text-spy-ink{% endif %}"
          style="font-family: var(--font-heading--family);"
          {% if link.current %}
            aria-current="page"
          {% endif %}
        >
          {{- link.title -}}
        </a>

        {% if link.links != blank %}
          <div class="invisible opacity-0 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100 absolute left-0 right-0 top-full z-40 bg-white border-t border-[#e5e5e5] shadow-lg transition-opacity duration-200">
            <div class="px-4">
              <div class="[display:grid] grid-cols-6 gap-x-6 lg:gap-x-8 pt-6 pb-16">
                <div class="hidden xl:flex xl:col-span-1 justify-center pt-16">
                  <span class="text-[26px] lg:text-[28px] leading-none font-bold uppercase text-spy-ink text-center" style="font-family: var(--font-heading--family);">{{ link.title }}</span>
                </div>
                <div class="col-span-4 xl:col-span-3 [display:grid] grid-cols-3 gap-x-6 lg:gap-x-10 gap-y-16 content-start pt-4">
                  {% for child in link.links %}
                    <div>
                      <a href="{{ child.url }}" class="inline-block pb-2 text-[14px] font-bold uppercase tracking-[0.5px] text-spy-ink no-underline hover:text-spy-orange" style="font-family: var(--font-heading--family);">{{ child.title }}</a>
                      {% if child.links != blank %}
                        <ul class="flex flex-col gap-0 list-none m-0 p-0">
                          {% for grandchild in child.links %}
                            <li>
                              <a href="{{ grandchild.url }}" class="inline-block py-[1px] text-[14px] leading-[22.4px] tracking-[0.5px] text-spy-ink no-underline hover:text-spy-orange">{{ grandchild.title }}</a>
                            </li>
                          {% endfor %}
                        </ul>
                      {% endif %}
                    </div>
                  {% endfor %}
                </div>
                {% comment %} Menu-images blocks get placed in here by their own script {% endcomment %}
                <div
                  class="col-span-2 [display:grid] grid-cols-2 gap-x-8 gap-y-6 content-start pt-4"
                  data-promo-slot="{{ link_handle }}"
                ></div>
              </div>
            </div>
          </div>
        {% endif %}
      </li>
    {% endfor %}
  </ul>

  <button
    type="button"
    class="spy-nav-toggle relative z-[70] flex items-center justify-center w-11 h-11 cursor-pointer text-spy-ink md:hidden button-unstyled"
    aria-label="{{ 'accessibility.menu' | t }}"
    aria-expanded="false"
    aria-controls="spy-mobile-nav"
  >
    <span class="block w-5 h-5">{{- 'spy-fa-bars.svg' | inline_asset_content -}}</span>
  </button>

  <div id="spy-mobile-nav" class="spy-nav md:hidden fixed inset-0 z-[60] invisible pointer-events-none [html.spy-nav-open_&]:visible" aria-hidden="true">
    <div class="spy-nav__overlay absolute top-[var(--spy-nav-top,50px)] left-0 right-0 bottom-0 bg-black/40 opacity-0 transition-opacity duration-[350ms] ease-spy-nav touch-none overscroll-contain pointer-events-auto [html.spy-nav-open_&]:opacity-100 motion-reduce:transition-none" data-nav-close></div>

    <div class="spy-nav__panel absolute left-0 top-0 bottom-0 w-[var(--spy-nav-width)] bg-white overflow-hidden -translate-x-full transition-[translate] duration-[350ms] ease-spy-nav pointer-events-auto [html.spy-nav-open_&]:translate-x-0 motion-reduce:transition-none">
      <div class="spy-nav__screens absolute inset-0">
        {% comment %} ROOT SCREEN {% endcomment %}
        <div class="spy-nav__screen is-root" data-screen="root">
          <ul class="list-none m-0 p-0 pt-1">
            {% for link in menu.links %}
              {% liquid
                assign is_highlight = false
                assign lh = link.title | handleize
                if lh == highlight_handle and highlight_handle != blank
                  assign is_highlight = true
                endif
              %}
              <li>
                {% if link.links != blank %}
                  <button
                    type="button"
                    data-nav-forward="scr-{{ forloop.index }}"
                    class="button-unstyled flex items-center justify-between w-full px-5 py-[16px] text-left cursor-pointer text-[13px] font-bold uppercase tracking-[0.5px] {% if is_highlight %}text-spy-orange{% else %}text-spy-ink{% endif %}"
                    style="font-family: var(--font-heading--family);"
                  >
                    {{ link.title }}
                    <span class="spy-caret-right -rotate-90 block w-2.5 h-2.5">{{- 'spy-fa-angle.svg' | inline_asset_content -}}</span>
                  </button>
                {% else %}
                  <a href="{{ link.url }}" class="block px-5 py-[16px] text-[13px] font-bold uppercase tracking-[0.5px] no-underline {% if is_highlight %}text-spy-orange{% else %}text-spy-ink{% endif %}" style="font-family: var(--font-heading--family);">{{- link.title -}}</a>
                {% endif %}
              </li>
            {% endfor %}
          </ul>

          <div class="border-t border-[#efefef] mt-1 pt-1">
            {% if shop.customer_accounts_enabled %}
              <a href="{{ routes.account_url }}" class="flex items-center gap-2.5 px-5 py-3 text-[13px] font-bold uppercase tracking-[0.5px] text-spy-ink no-underline" style="font-family: var(--font-heading--family);">
                <span class="block w-[14px] h-[14px]">{{- 'spy-fa-user.svg' | inline_asset_content -}}</span>
                {% if customer %}{{ 'content.account_title' | t }}{% else %}{{ 'actions.log_in' | t }}{% endif %}
              </a>
            {% endif %}
            {% if block.settings.store_locator_url != blank %}
              <a href="{{ block.settings.store_locator_url }}" target="_blank" rel="noopener" class="flex items-center gap-2.5 px-5 py-3 text-[13px] font-bold uppercase tracking-[0.5px] text-spy-ink no-underline" style="font-family: var(--font-heading--family);">
                <span class="block w-[14px] h-[14px]">{{- 'spy-fa-location.svg' | inline_asset_content -}}</span>
                {{ block.settings.store_locator_label }}
              </a>
            {% endif %}
            {% if localization.available_countries.size > 1 %}
              <a href="#" class="flex items-center justify-between gap-2.5 px-5 py-3 text-[13px] font-bold uppercase tracking-[0.5px] text-spy-ink no-underline" style="font-family: var(--font-heading--family);">
                {{ localization.country.name }} ({{ localization.language.iso_code | upcase }})
                <span class="spy-caret-right -rotate-90 block w-2.5 h-2.5 text-[#9a9a9a]">{{- 'spy-fa-angle.svg' | inline_asset_content -}}</span>
              </a>
            {% endif %}
          </div>
        </div>

        {% comment %} CATEGORY SCREENS {% endcomment %}
        {% for link in menu.links %}
          {% if link.links != blank %}
            {% liquid
              assign link_handle = link.title | handleize
              assign opened_one = false
            %}
            <div class="spy-nav__screen" data-screen="scr-{{ forloop.index }}">
              <button
                type="button"
                data-nav-back
                class="button-unstyled flex items-center gap-3 w-full px-5 py-[15px] text-left cursor-pointer text-[13px] font-bold uppercase tracking-[0.5px] text-spy-ink"
                style="font-family: var(--font-heading--family);"
              >
                <span class="spy-caret-back rotate-90 block w-2.5 h-2.5 text-spy-ink">{{- 'spy-fa-angle.svg' | inline_asset_content -}}</span>
                {{ link.title }}
              </button>

              <div class="spy-nav__body flex-auto">
                <a href="{{ link.url }}" class="block px-5 py-3 text-[13px] font-bold uppercase tracking-[0.5px] text-spy-ink no-underline" style="font-family: var(--font-heading--family);">See all {{ link.title }}</a>

                {% for child in link.links %}
                  {% if child.links != blank %}
                    {% liquid
                      assign is_open = false
                      if opened_one == false
                        assign is_open = true
                        assign opened_one = true
                      endif
                    %}
                    <details class="spy-l2 group/l2 open:bg-[#f5f5f5]" {% if is_open %}open{% endif %}>
                      <summary class="flex items-center justify-between px-5 py-3 cursor-pointer list-none text-[13px] font-bold uppercase tracking-[0.5px] text-spy-ink [&::-webkit-details-marker]:hidden" style="font-family: var(--font-heading--family);">
                        {{ child.title }}
                        <span class="spy-caret block w-2.5 h-2.5 text-[#9a9a9a]">{{- 'spy-fa-angle.svg' | inline_asset_content -}}</span>
                      </summary>
                      <div class="spy-acc__wrap overflow-hidden transition-[height] duration-[350ms] ease-spy-nav [will-change:height] motion-reduce:transition-none"><div class="spy-acc__inner pb-2 opacity-0 transition-opacity duration-300 ease-spy-nav delay-[50ms] group-open/l2:opacity-100 motion-reduce:transition-none">
                        <a href="{{ child.url }}" class="spy-acc__row block px-5 pt-1 pb-2.5 text-[13px] font-bold uppercase tracking-[0.5px] text-spy-ink no-underline" style="font-family: var(--font-heading--family);">See all {{ child.title }}</a>
                        {% for grandchild in child.links %}
                          <a href="{{ grandchild.url }}" class="spy-acc__row block px-5 py-2.5 text-[13px] font-bold uppercase tracking-[0.5px] text-spy-ink no-underline" style="font-family: var(--font-heading--family);">{{ grandchild.title }}</a>
                        {% endfor %}
                      </div></div>
                    </details>
                  {% else %}
                    <a href="{{ child.url }}" class="block px-5 py-3 text-[13px] font-bold uppercase tracking-[0.5px] text-spy-ink no-underline" style="font-family: var(--font-heading--family);">{{ child.title }}</a>
                  {% endif %}
                {% endfor %}

                <div class="[display:grid] grid-cols-1 gap-y-5 pt-5 pb-6" data-promo-slot-mobile="{{ link_handle }}"></div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <script>
    (() => {
      const nav = document.getElementById('spy-mobile-nav');
      const toggle = document.querySelector('.spy-nav-toggle');
      if (!nav || !toggle) return;

      if (nav.parentElement !== document.body) document.body.appendChild(nav);
      const root = document.documentElement;
      const screens = nav.querySelectorAll('[data-screen]');

      const resetScreens = () =>
        screens.forEach((s) => {
          if (!s.classList.contains('is-root')) s.classList.remove('is-active');
        });


        const setNavTop = () => {
        const header = document.querySelector('.spy-header-section');
        const h = header ? Math.round(header.getBoundingClientRect().height) : 50;
        root.style.setProperty('--spy-nav-top', h + 'px');
      };

      const open = () => {
        setNavTop();
        root.classList.add('spy-nav-open');
        toggle.setAttribute('aria-expanded', 'true');
        nav.setAttribute('aria-hidden', 'false');
      };
      const close = () => {
        root.classList.remove('spy-nav-open');
        toggle.setAttribute('aria-expanded', 'false');
        nav.setAttribute('aria-hidden', 'true');
        setTimeout(resetScreens, 300);
      };

      toggle.addEventListener('click', () =>
        root.classList.contains('spy-nav-open') ? close() : open()
      );

      nav.addEventListener('click', (e) => {
        const fwd = e.target.closest('[data-nav-forward]');
        if (fwd) {
          const target = nav.querySelector('[data-screen="' + fwd.dataset.navForward + '"]');
          if (target) {
            target.classList.add('is-active');
            target.scrollTop = 0;
          }
          return;
        }
        const back = e.target.closest('[data-nav-back]');
        if (back) {
          back.closest('[data-screen]').classList.remove('is-active');
          return;
        }
        if (e.target.closest('[data-nav-close]')) close();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && root.classList.contains('spy-nav-open')) close();
      });

      /* Animate the sub-category accordions. Native <details> can't tween its
         own open/close, so we intercept the summary click, drive the wrapper's
         height between 0 and its natural height, and only flip the [open]
         attribute at the right moment. */
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      nav.querySelectorAll('details.spy-l2').forEach((d) => {
        const summary = d.querySelector('summary');
        const wrap = d.querySelector('.spy-acc__wrap');
        if (!summary || !wrap) return;

        summary.addEventListener('click', (e) => {
          if (reduceMotion.matches) return; /* let the browser toggle instantly */
          e.preventDefault();
          if (d.dataset.anim) return;
          d.dataset.anim = '1';

          const closing = d.open;
          if (!closing) d.open = true; /* render content so we can measure it */
          /* [open] is removed only when the collapse finishes, so flip the caret
             down right away via a transient class for immediate feedback. */
          if (closing) d.classList.add('acc-collapsing');

          const from = closing ? wrap.scrollHeight : 0;
          const to = closing ? 0 : wrap.scrollHeight;
          wrap.style.height = from + 'px';
          void wrap.offsetHeight; /* force reflow so the next change transitions */
          wrap.style.height = to + 'px';

          let done = false;
          const finish = () => {
            if (done) return;
            done = true;
            wrap.style.height = '';
            if (closing) d.open = false;
            d.classList.remove('acc-collapsing');
            delete d.dataset.anim;
            wrap.removeEventListener('transitionend', onEnd);
          };
          const onEnd = (ev) => {
            if (ev.propertyName === 'height') finish();
          };
          wrap.addEventListener('transitionend', onEnd);
          setTimeout(finish, 450); /* fallback if transitionend never fires */
        });
      });
    })();
  </script>
</nav>

{% schema %}
{
  "name": "SPY Mega Menu",
  "tag": null,
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "highlight_item",
      "label": "Item title to highlight",
      "info": "Menu item with this title shows in the brand orange (e.g. Sale)",
      "default": "Sale"
    },
    {
      "type": "header",
      "content": "Mobile drawer footer"
    },
    {
      "type": "text",
      "id": "store_locator_url",
      "label": "Store locator link",
      "info": "Shown as \"Find a store\" in the mobile menu. Leave blank to hide.",
      "default": "https://stores.spyoptic.com"
    },
    {
      "type": "text",
      "id": "store_locator_label",
      "label": "Store locator label",
      "default": "Find a store"
    }
  ],
  "presets": [
    {
      "name": "SPY Mega Menu"
    }
  ]
}
{% endschema %}
