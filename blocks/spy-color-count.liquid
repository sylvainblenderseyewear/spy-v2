{%- liquid
  assign p = closest.product
  assign color_option = nil
  for opt in p.options_with_values
    assign opt_lower = opt.name | downcase
    if opt_lower == 'frame color' or opt_lower == 'color' or opt_lower == 'colour'
      assign color_option = opt
      break
    endif
  endfor

  # Many colours -> count; single colour -> its name; none -> empty but reserved
  assign label = ''
  if color_option != nil
    assign cc = color_option.values.size
    if cc > 1
      assign label = cc | append: ' colors available'
    else
      assign label = color_option.values.first.name
    endif
  endif
-%}

{%- comment -%} Always rendered so the slot keeps its height, even with no colour data {%- endcomment -%}
<p class="spy-color-count text-[10px] font-semibold text-spy-gray m-0" {{ block.shopify_attributes }}>{{ label }}</p>

{% schema %}
{
  "name": "Color Count",
  "tag": null,
  "settings": [],
  "presets": [
    {
      "name": "Color Count",
      "category": "SPY"
    }
  ]
}
{% endschema %}
