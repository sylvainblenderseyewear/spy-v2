{%- liquid
  assign p = closest.product
  assign vlt         = p.metafields.spec.vlt_percent.value
  assign lens_cat    = p.metafields.spec.lens_category.value
  assign base_tint   = p.metafields.spec.base_tint.value
  assign technologies = p.metafields.spec.technologies.value

  if vlt == blank and lens_cat == blank and base_tint == blank and technologies == blank
    assign skip_block = true
  endif

  # Parse category number (handles "Cat. 3", "Cat. 1 (Clear) / Cat. 3", "3")
  assign cat_clean = lens_cat | downcase | remove: 'cat. ' | remove: 'cat.' | remove: 'cat ' | strip | split: ' ' | first
  assign cat_num = cat_clean | plus: 0
  assign show_scale = false
  unless cat_clean == blank
    assign show_scale = true
  endunless
-%}

{%- unless skip_block -%}
<div class="spy-lens-info" {{ block.shopify_attributes }}>

  <div class="spy-lens-info__header">
    <span class="spy-lens-info__title">Lens information</span>
  </div>

  <div class="spy-lens-info__grid">

    {%- if vlt != blank -%}
      <div class="spy-lens-info__cell">
        <span class="spy-lens-info__value">{{ vlt }}%</span>
        <span class="spy-lens-info__label">Visible Light Transmission (VLT)</span>
      </div>
    {%- endif -%}

    {%- if lens_cat != blank -%}
      <div class="spy-lens-info__cell">
        <span class="spy-lens-info__value">{{ cat_num }}</span>
        <span class="spy-lens-info__label">Lens category</span>
      </div>
    {%- endif -%}

    {%- if base_tint != blank -%}
      <div class="spy-lens-info__cell">
        <span class="spy-lens-info__value spy-lens-info__value--md">{{ base_tint }}</span>
        <span class="spy-lens-info__label">Tint base</span>
      </div>
    {%- endif -%}

    {%- if technologies != blank -%}
      {%- assign first_tech = technologies | first -%}
      {%- if first_tech != blank -%}
        {%- assign tech_name = first_tech.fields.name.value -%}
        {%- assign tech_icon_file = first_tech.fields.icon.value -%}
        {%- assign icon_src = tech_icon_file | image_url: width: 120 -%}
        {%- if icon_src == blank -%}{%- assign icon_src = tech_icon_file.url -%}{%- endif -%}
        <div class="spy-lens-info__cell">
          <span class="spy-lens-info__value spy-lens-info__value--tech">
            {%- if icon_src != blank -%}
              <img src="{{ icon_src }}" alt="{{ tech_name }}" width="80" height="28" loading="lazy" class="spy-lens-info__tech-img">
            {%- else -%}
              {{- tech_name -}}
            {%- endif -%}
          </span>
          <span class="spy-lens-info__label">Technology</span>
        </div>
      {%- endif -%}
    {%- endif -%}

  </div>

  {%- if show_scale -%}
    <div class="spy-lens-info__scale">
      {%- for i in (0..4) -%}
        {%- assign is_active = false -%}
        {%- if i == cat_num -%}{%- assign is_active = true -%}{%- endif -%}
        <div class="spy-lens-info__scale-step{% if is_active %} spy-lens-info__scale-step--active{% endif %}">
          <span class="spy-lens-info__scale-icon" aria-hidden="true">
            {%- case i -%}
              {%- when 0 -%}
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M15.5 14H5a4 4 0 0 1-.3-8 4.5 4.5 0 0 1 8.9 1H14a2.5 2.5 0 0 1 1.5 4.5Z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {%- when 1 -%}
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M15.5 14H5a4 4 0 0 1-.3-8 4.5 4.5 0 0 1 8.9 1H14a2.5 2.5 0 0 1 1.5 4.5Z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {%- when 2 -%}
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="11.5" cy="7.5" r="3" stroke="currentColor" stroke-width="1.2"/><path d="M8.5 14H4a3.5 3.5 0 0 1-.3-7 4 4 0 0 1 6.3-2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              {%- when 3 -%}
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="4" stroke="currentColor" stroke-width="1.2"/><line x1="10" y1="2" x2="10" y2="3.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="10" y1="16.5" x2="10" y2="18" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="2" y1="10" x2="3.5" y2="10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="16.5" y1="10" x2="18" y2="10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="4.22" y1="4.22" x2="5.28" y2="5.28" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="14.72" y1="14.72" x2="15.78" y2="15.78" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="14.72" y1="5.28" x2="15.78" y2="4.22" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="4.22" y1="15.78" x2="5.28" y2="14.72" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              {%- when 4 -%}
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="3.5" stroke="currentColor" stroke-width="1.2"/><line x1="10" y1="1" x2="10" y2="3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="10" y1="17" x2="10" y2="19" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="1" y1="10" x2="3" y2="10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="17" y1="10" x2="19" y2="10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="3.34" y1="3.34" x2="4.75" y2="4.75" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="15.25" y1="15.25" x2="16.66" y2="16.66" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="15.25" y1="4.75" x2="16.66" y2="3.34" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="3.34" y1="16.66" x2="4.75" y2="15.25" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="6.5" y1="1" x2="6.5" y2="3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="13.5" y1="1" x2="13.5" y2="3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
            {%- endcase -%}
          </span>
          <span class="spy-lens-info__scale-bar" aria-hidden="true"></span>
          <span class="spy-lens-info__scale-label">Cat.&thinsp;{{ i }}</span>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

</div>
{%- endunless -%}

{% schema %}
{
  "name": "Lens Info",
  "tag": null,
  "settings": [],
  "presets": [
    {
      "name": "Lens Info",
      "category": "SPY"
    }
  ]
}
{% endschema %}
