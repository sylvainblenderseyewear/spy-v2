{%- liquid
  assign p = closest.product
  assign g = p.metafields.goggle
  assign fit_base   = g.base.value
  assign fit_system = g.fit_system.value
  assign ventilation = g.ventilation.value
  assign fit_a = g.fit_a_mm.value
  assign fit_b = g.fit_b_mm.value
  assign fit_c = g.fit_c_mm.value
  assign fit_d = g.fit_d_mm.value

  if fit_base == blank and fit_system == blank and ventilation == blank
    assign skip_block = true
  endif
-%}

{%- unless skip_block -%}
<div class="border-t border-spy-border py-3 flex flex-col gap-1.5" {{ block.shopify_attributes }}>

  {%- if fit_base != blank -%}
  <div class="flex justify-between items-baseline gap-2">
    <span class="text-[11px] font-bold uppercase tracking-[0.07em] text-spy-gray flex-shrink-0">{{ block.settings.fit_label | default: 'Base / Fit' }}</span>
    <span class="text-[13px] font-semibold text-spy-slate text-right">{{ fit_base }}</span>
  </div>
  {%- endif -%}

  {%- if fit_system != blank -%}
  <div class="flex justify-between items-baseline gap-2">
    <span class="text-[11px] font-bold uppercase tracking-[0.07em] text-spy-gray flex-shrink-0">Fit System</span>
    <span class="text-[13px] font-semibold text-spy-slate text-right">{{ fit_system }}</span>
  </div>
  {%- endif -%}

  {%- if ventilation != blank -%}
  <div class="flex justify-between items-baseline gap-2">
    <span class="text-[11px] font-bold uppercase tracking-[0.07em] text-spy-gray flex-shrink-0">Ventilation</span>
    <span class="text-[13px] font-semibold text-spy-slate text-right">{{ ventilation }}</span>
  </div>
  {%- endif -%}

  {%- if fit_a != blank or fit_b != blank or fit_c != blank or fit_d != blank -%}
  <div class="flex flex-wrap gap-2 pt-1">
    {%- if fit_a != blank -%}
      <div class="flex flex-col items-center min-w-[52px] px-2.5 py-1.5 border border-spy-border gap-0.5">
        <span class="text-[10px] font-bold uppercase tracking-[0.08em] text-spy-orange">A</span>
        <span class="text-[13px] font-semibold text-spy-slate">{{ fit_a }}&thinsp;mm</span>
      </div>
    {%- endif -%}
    {%- if fit_b != blank -%}
      <div class="flex flex-col items-center min-w-[52px] px-2.5 py-1.5 border border-spy-border gap-0.5">
        <span class="text-[10px] font-bold uppercase tracking-[0.08em] text-spy-orange">B</span>
        <span class="text-[13px] font-semibold text-spy-slate">{{ fit_b }}&thinsp;mm</span>
      </div>
    {%- endif -%}
    {%- if fit_c != blank -%}
      <div class="flex flex-col items-center min-w-[52px] px-2.5 py-1.5 border border-spy-border gap-0.5">
        <span class="text-[10px] font-bold uppercase tracking-[0.08em] text-spy-orange">C</span>
        <span class="text-[13px] font-semibold text-spy-slate">{{ fit_c }}&thinsp;mm</span>
      </div>
    {%- endif -%}
    {%- if fit_d != blank -%}
      <div class="flex flex-col items-center min-w-[52px] px-2.5 py-1.5 border border-spy-border gap-0.5">
        <span class="text-[10px] font-bold uppercase tracking-[0.08em] text-spy-orange">D</span>
        <span class="text-[13px] font-semibold text-spy-slate">{{ fit_d }}&thinsp;mm</span>
      </div>
    {%- endif -%}
  </div>
  {%- endif -%}

  {%- if block.settings.guide_link != blank -%}
  <a href="{{ block.settings.guide_link }}" class="inline-block mt-1 text-[11px] font-bold uppercase tracking-[0.06em] text-spy-slate underline underline-offset-[3px] hover:text-spy-orange transition-colors">
    {{- block.settings.guide_link_label | default: 'View Fit Guide' -}}
  </a>
  {%- endif -%}

</div>
{%- endunless -%}

{% schema %}
{
  "name": "Goggle Fit Guide",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "fit_label",
      "label": "Fit row label",
      "default": "Base / Fit"
    },
    {
      "type": "url",
      "id": "guide_link",
      "label": "Fit guide page link"
    },
    {
      "type": "text",
      "id": "guide_link_label",
      "label": "Fit guide link label",
      "default": "View Fit Guide"
    }
  ],
  "presets": [
    {
      "name": "Goggle Fit Guide",
      "category": "SPY"
    }
  ]
}
{% endschema %}
