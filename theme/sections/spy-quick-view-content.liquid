{%- liquid
  assign p           = product
  assign vlt          = p.metafields.spec.vlt_percent.value
  assign lens_cat     = p.metafields.spec.lens_category.value
  assign base_tint    = p.metafields.spec.base_tint.value
  assign mirror_tint  = p.metafields.spec.mirror_tint.value
  assign polarized    = p.metafields.spec.polarized.value
  assign technologies = p.metafields.spec.technologies.value
  assign avail_v      = p.selected_or_first_available_variant
-%}

<div class="spy-qv-content" data-product-id="{{ p.id }}" data-product-handle="{{ p.handle }}">

  <div class="mb-4">
    <h2 class="text-[clamp(1.25rem,3vw,1.75rem)] font-bold uppercase leading-[1.1] m-0 mb-2 text-spy-slate">{{ p.title }}</h2>
    <div class="spy-qv-content__price text-base font-semibold">
      {%- if avail_v.compare_at_price > avail_v.price -%}
        <span class="spy-qv-content__price--sale text-[#e53935]">{{ avail_v.price | money }}</span>
        <s class="spy-qv-content__price--compare text-[#999] ml-1.5 font-normal text-sm">{{ avail_v.compare_at_price | money }}</s>
      {%- else -%}
        <span>{{ avail_v.price | money }}</span>
      {%- endif -%}
    </div>
  </div>

  {%- if lens_cat != blank or vlt != blank or base_tint != blank or technologies != blank -%}
  <div class="flex flex-wrap gap-x-4 gap-y-2 py-3 border-t border-b border-spy-border mb-5">
    {%- if lens_cat != blank -%}
      <div class="flex flex-col gap-0.5 min-w-[60px]">
        <span class="text-[10px] font-bold uppercase tracking-[0.08em] text-spy-gray">Lens</span>
        <span class="text-[13px] font-semibold text-spy-slate">{{ lens_cat }}</span>
      </div>
    {%- endif -%}
    {%- if vlt != blank -%}
      <div class="flex flex-col gap-0.5 min-w-[60px]">
        <span class="text-[10px] font-bold uppercase tracking-[0.08em] text-spy-gray">VLT</span>
        <span class="text-[13px] font-semibold text-spy-slate">{{ vlt }}%</span>
      </div>
    {%- endif -%}
    {%- if base_tint != blank -%}
      <div class="flex flex-col gap-0.5 min-w-[60px]">
        <span class="text-[10px] font-bold uppercase tracking-[0.08em] text-spy-gray">Base Tint</span>
        <span class="text-[13px] font-semibold text-spy-slate">{{ base_tint }}</span>
      </div>
    {%- endif -%}
    {%- if mirror_tint != blank -%}
      <div class="flex flex-col gap-0.5 min-w-[60px]">
        <span class="text-[10px] font-bold uppercase tracking-[0.08em] text-spy-gray">Mirror</span>
        <span class="text-[13px] font-semibold text-spy-slate">{{ mirror_tint }}</span>
      </div>
    {%- endif -%}
    {%- if polarized -%}
      <div class="flex flex-col gap-0.5 min-w-[60px]">
        <span class="text-[10px] font-bold uppercase tracking-[0.08em] text-spy-gray">Polarized</span>
        <span class="text-[13px] font-semibold text-spy-slate">Yes</span>
      </div>
    {%- endif -%}
    {%- if technologies != blank -%}
      <div class="w-full flex flex-wrap gap-1.5 pt-2">
        {%- for tech in technologies -%}
          {%- assign tech_name = tech.fields.name.value -%}
          {%- if tech_name != blank -%}
            <span class="inline-flex items-center gap-1 text-[11px] font-bold uppercase tracking-[0.05em] text-spy-orange border border-spy-orange px-2 py-0.5">{{- tech_name -}}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
  {%- endif -%}

  {%- form 'product', p, id: 'spy-qv-form', class: 'spy-qv-content__form' -%}
    {%- for option in p.options_with_values -%}
      {%- assign opt_idx = option.position | minus: 1 -%}
      {%- assign selected_val = avail_v.options[opt_idx] -%}
      <div class="mb-4">
        <p class="text-xs font-bold uppercase tracking-[0.06em] m-0 mb-2 text-spy-slate">
          {{ option.name }}:
          <span class="spy-qv-content__option-selected font-normal normal-case" data-position="{{ option.position }}">{{ selected_val }}</span>
        </p>
        <div class="flex flex-wrap gap-1.5">
          {%- for value in option.values -%}
            <button
              type="button"
              class="spy-qv-content__swatch px-3 py-1.5 border border-spy-border bg-transparent cursor-pointer text-xs font-semibold text-spy-slate transition-colors hover:border-spy-orange hover:text-spy-orange{% if value == selected_val %} !bg-spy-slate !text-white !border-spy-slate{% endif %}"
              data-option-position="{{ option.position }}"
              data-option-value="{{ value | escape }}"
            >{{ value }}</button>
          {%- endfor -%}
        </div>
      </div>
    {%- endfor -%}

    <input type="hidden" name="id" value="{{ avail_v.id }}">

    <div class="flex flex-col gap-2.5 mt-5 mb-5">
      <button
        type="submit"
        class="w-full py-3.5 px-6 bg-spy-orange text-white border-0 cursor-pointer text-[13px] font-bold uppercase tracking-[0.08em] transition-opacity hover:opacity-[0.88] disabled:opacity-45 disabled:cursor-not-allowed"
        {% unless avail_v.available %}disabled{% endunless %}
      >
        {%- if avail_v.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
      </button>
      <a href="{{ p.url }}" class="block text-center text-xs font-semibold uppercase tracking-[0.06em] text-spy-slate no-underline py-1.5 border-b border-current w-fit mx-auto">View Full Details &#x2192;</a>
    </div>
  {%- endform -%}

  {%- assign has_spec = false -%}
  {%- if p.metafields.spec.reference.value != blank
    or p.metafields.spec.fit.value != blank
    or p.metafields.spec.weight_g.value != blank
    or p.metafields.spec.frame_material.value != blank -%}
    {%- assign has_spec = true -%}
  {%- endif -%}

  {%- if has_spec -%}
  <details class="spy-spec-table mt-2">
    <summary>Technical Information</summary>
    <table class="spy-spec-table__table">
      {%- if p.metafields.spec.reference.value != blank -%}
        <tr><th>Reference</th><td>{{ p.metafields.spec.reference.value }}</td></tr>
      {%- endif -%}
      {%- if p.metafields.spec.fit.value != blank -%}
        <tr><th>Fit</th><td>{{ p.metafields.spec.fit.value }}</td></tr>
      {%- endif -%}
      {%- if p.metafields.spec.weight_g.value != blank -%}
        <tr><th>Weight</th><td>{{ p.metafields.spec.weight_g.value }}g</td></tr>
      {%- endif -%}
      {%- if p.metafields.spec.frame_material.value != blank -%}
        <tr><th>Frame Material</th><td>{{ p.metafields.spec.frame_material.value }}</td></tr>
      {%- endif -%}
      {%- if p.metafields.spec.lens_material.value != blank -%}
        <tr><th>Lens Material</th><td>{{ p.metafields.spec.lens_material.value }}</td></tr>
      {%- endif -%}
      {%- if p.metafields.spec.lens_coating.value != blank -%}
        <tr><th>Lens Coating</th><td>{{ p.metafields.spec.lens_coating.value }}</td></tr>
      {%- endif -%}
    </table>
  </details>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "Quick View Content",
  "settings": []
}
{% endschema %}
