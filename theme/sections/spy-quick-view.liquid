<div class="spy-qv-wrapper" {{ section.shopify_attributes }}>
  <div class="spy-qv-overlay"></div>
  <div
    class="spy-qv-modal"
    role="dialog"
    aria-modal="true"
    aria-label="Quick View"
    aria-hidden="true"
  >
    <button class="spy-qv-modal__close absolute top-3 right-3 bg-transparent border-0 cursor-pointer p-1.5 flex items-center justify-center text-spy-slate hover:text-spy-orange transition-colors" type="button" aria-label="Close quick view">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M15 5L5 15M5 5l10 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    <div class="spy-qv-modal__content"></div>
  </div>
</div>

{{ 'spy-quick-view.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Quick View Modal",
  "settings": []
}
{% endschema %}
