{%- liquid
  assign desktop_img = section.settings.image_desktop
  assign mobile_img  = section.settings.image_mobile
  if desktop_img == blank and mobile_img == blank
    assign skip_section = true
  endif
-%}

{%- unless skip_section -%}
{%- assign banner_alt = section.settings.heading | escape -%}
<div class="spy-feature-link-banner relative w-full overflow-hidden" {{ section.shopify_attributes }}>
  {%- if section.settings.link != blank -%}
    <a
      href="{{ section.settings.link }}"
      class="group block no-underline"
      aria-label="{{ section.settings.eyebrow | default: section.settings.heading | escape }}"
    >
  {%- endif -%}

  {%- comment -%} Desktop image {%- endcomment -%}
  {%- if desktop_img != blank -%}
    {{
      desktop_img
      | image_url: width: 2000
      | image_tag:
        loading: 'lazy',
        alt: banner_alt,
        sizes: '100vw',
        widths: '750, 1100, 1500, 2000',
        class: 'hidden md:block w-full h-auto object-cover transition-transform duration-500 ease-in-out group-hover:scale-[1.02]'
    }}
  {%- endif -%}

  {%- comment -%} Mobile image (falls back to desktop) {%- endcomment -%}
  {%- if mobile_img != blank -%}
    {{
      mobile_img
      | image_url: width: 800
      | image_tag:
        loading: 'lazy',
        alt: banner_alt,
        sizes: '100vw',
        widths: '390, 550, 800',
        class: 'block md:hidden w-full h-auto object-cover'
    }}
  {%- elsif desktop_img != blank -%}
    {{
      desktop_img
      | image_url: width: 800
      | image_tag:
        loading: 'lazy',
        alt: banner_alt,
        sizes: '100vw',
        widths: '390, 550, 800',
        class: 'block md:hidden w-full h-auto object-cover'
    }}
  {%- endif -%}

  {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.cta_label != blank -%}
    {%- liquid
      case section.settings.content_align
        when 'center'
          assign align_classes = 'items-center text-center'
        when 'right'
          assign align_classes = 'items-end text-right'
        else
          assign align_classes = 'items-start text-left'
      endcase
    -%}
    <div class="absolute inset-x-0 bottom-0 flex flex-col gap-2 {{ align_classes }} px-6 pb-12 pt-24 bg-gradient-to-t from-black/55 to-transparent pointer-events-none md:px-12">
      {%- if section.settings.eyebrow != blank -%}
        <span class="text-spy-orange text-[11px] font-bold uppercase tracking-widest leading-none">
          {{ section.settings.eyebrow }}
        </span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="text-white font-bold uppercase leading-none m-0 text-4xl md:text-6xl lg:text-7xl tracking-tight">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <span class="inline-block text-white text-xs font-bold uppercase tracking-widest border-b border-white/60 pb-0.5 mt-2 leading-none pointer-events-auto">
          {{ section.settings.cta_label }}
        </span>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.settings.link != blank -%}
    </a>
  {%- endif -%}
</div>
{%- endunless -%}

{% schema %}
{
  "name": "Feature Link Banner",
  "tag": "div",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image",
      "info": "Falls back to desktop image if blank"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Content alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Feature Link Banner",
      "category": "SPY"
    }
  ]
}
{% endschema %}
