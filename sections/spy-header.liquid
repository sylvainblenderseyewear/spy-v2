<div
  class="relative z-50 bg-white"
  {% if section.settings.sticky %}
    data-spy-sticky
  {% endif %}
>
  {%- if request.page_type == 'index' -%}
    <h1 class="sr-only">{{ shop.name }}</h1>
  {%- endif -%}
  <div class="section section--page-width md:[--page-width:calc(87vw_+_var(--page-margin)*2)] border-b border-[#e5e5e5]">
    <div class="flex items-center gap-3 md:gap-4 min-h-[49px]">
      <div class="flex items-center shrink-0">
        <a
          href="{{ routes.root_url }}"
          class="svg-logo-container inline-flex items-center [&_svg]:block [&_svg]:h-[var(--spy-logo-h-m,28px)] [&_svg]:w-[calc(var(--spy-logo-h-m,28px)*66/28)] min-[750px]:[&_svg]:h-[var(--spy-logo-h,36px)] min-[750px]:[&_svg]:w-[calc(var(--spy-logo-h,36px)*79/36)]"
          style="--spy-logo-h: {{ settings.logo_height | default: 36 }}px; --spy-logo-h-m: {{ settings.logo_height_mobile | default: 28 }}px;"
          aria-label="{{ shop.name }}"
        >
          {{- 'spy-logo.svg' | inline_asset_content -}}
        </a>
      </div>
      {% content_for 'blocks' %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "SPY Header",
  "tag": "header",
  "class": "spy-header-section",
  "blocks": [
    {
      "type": "spy-mega-menu"
    },
    {
      "type": "spy-utility-nav"
    },
    {
      "type": "spy-menu-promo"
    }
  ],
  "settings": [
    {
      "type": "checkbox",
      "id": "sticky",
      "label": "Sticky header",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "SPY Header",
      "blocks": [
        {
          "type": "spy-mega-menu"
        },
        {
          "type": "spy-utility-nav"
        }
      ]
    }
  ]
}
{% endschema %}
