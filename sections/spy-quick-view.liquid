<div class="spy-qv-wrapper group" {{ section.shopify_attributes }}>
  <div class="spy-qv-overlay fixed inset-0 bg-black/55 z-[999] opacity-0 pointer-events-none transition-opacity duration-200 ease-[ease] group-data-[open]:opacity-100 group-data-[open]:pointer-events-auto"></div>
  <div
    class="spy-qv-modal fixed z-[1000] bg-white overflow-y-auto opacity-0 pointer-events-none transition-[opacity,translate] duration-200 ease-[ease] [-webkit-overflow-scrolling:touch] group-data-[open]:opacity-100 group-data-[open]:pointer-events-auto min-[750px]:top-1/2 min-[750px]:left-1/2 min-[750px]:-translate-x-1/2 min-[750px]:translate-y-[calc(-50%_+_16px)] min-[750px]:w-[min(660px,95vw)] min-[750px]:max-h-[90vh] min-[750px]:pt-10 min-[750px]:px-8 min-[750px]:pb-8 min-[750px]:group-data-[open]:translate-y-[-50%] max-[750px]:top-auto max-[750px]:right-0 max-[750px]:bottom-0 max-[750px]:left-0 max-[750px]:w-full max-[750px]:max-h-[92vh] max-[750px]:translate-y-[20px] max-[750px]:rounded-t-xl max-[750px]:pt-10 max-[750px]:px-5 max-[750px]:pb-8 max-[750px]:group-data-[open]:translate-y-0"
    role="dialog"
    aria-modal="true"
    aria-label="Quick View"
    aria-hidden="true"
  >
    <button class="spy-qv-modal__close absolute top-3 right-3 bg-transparent border-0 cursor-pointer p-1.5 flex items-center justify-center text-spy-slate hover:text-spy-orange transition-colors" type="button" aria-label="Close quick view">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M15 5L5 15M5 5l10 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    <div class="spy-qv-modal__content"></div>
  </div>
</div>

<script src="{{ 'spy-quick-view.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Quick View Modal",
  "settings": []
}
{% endschema %}
