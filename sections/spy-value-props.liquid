{%- comment -%}
  SPY Value Props — trust/value row built only from basic blocks.
  The band, lines and padding live on the section; each column is a
  Group block (icon + two Text blocks) so editors can add/remove columns.
  Icons are picked in the editor.
{%- endcomment -%}

<div
  class="spy-value-props w-full"
  style="
    background-color: {{ section.settings.background_color }};
    {% if section.settings.show_border %}border-block: 1px solid {{ section.settings.border_color }};{% endif %}
    padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
  "
  {{ section.shopify_attributes }}
>
  <div
    class="spy-value-props__inner mx-auto flex flex-col gap-y-10 px-4 md:px-10 md:flex-row md:justify-center md:items-start md:gap-y-0 [&>.group-block]:w-full md:[&>.group-block]:w-auto md:[&>.group-block]:flex-1 md:[&>.group-block]:min-w-0"
    style="max-width: {{ section.settings.max_width }}px; column-gap: {{ section.settings.column_gap }}px;"
  >
    {% content_for 'blocks' %}
  </div>
</div>

{% schema %}
{
  "name": "SPY Value Props",
  "tag": "section",
  "disabled_on": {
    "groups": ["header"]
  },
  "blocks": [
    { "type": "@theme" },
    { "type": "@app" }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Band"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f2f2f2"
    },
    {
      "type": "checkbox",
      "id": "show_border",
      "label": "Top & bottom lines",
      "default": true
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Line color",
      "default": "#e0e0e0",
      "visible_if": "{{ section.settings.show_border }}"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Content max width",
      "min": 800,
      "max": 2000,
      "step": 20,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Gap between columns",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 56
    }
  ],
  "presets": [
    {
      "name": "SPY Value Props",
      "category": "SPY",
      "settings": {
        "background_color": "#f2f2f2",
        "show_border": true,
        "border_color": "#e0e0e0",
        "max_width": 1400,
        "column_gap": 16,
        "padding_top": 56,
        "padding_bottom": 56
      },
      "blocks": {
        "col_1": {
          "type": "group",
          "name": "Free Shipping",
          "settings": {
            "content_direction": "column",
            "vertical_on_mobile": true,
            "horizontal_alignment_flex_direction_column": "center",
            "vertical_alignment_flex_direction_column": "flex-start",
            "gap": 16,
            "width": "fill",
            "height": "fit"
          },
          "blocks": {
            "icon": {
              "type": "icon",
              "settings": {
                "icon": "truck",
                "width": 52,
                "icon_color": "#2c393e"
              }
            },
            "text": {
              "type": "group",
              "settings": {
                "content_direction": "column",
                "horizontal_alignment_flex_direction_column": "center",
                "gap": 6,
                "width": "fill",
                "height": "fit"
              },
              "blocks": {
                "title": {
                  "type": "text",
                  "settings": {
                    "text": "<p><strong>Free Shipping</strong></p>",
                    "type_preset": "custom",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "width": "100%",
                    "max_width": "none",
                    "alignment": "center",
                    "text_color": "#2c393e"
                  }
                },
                "subtitle": {
                  "type": "text",
                  "settings": {
                    "text": "<p>for any order over $50</p>",
                    "type_preset": "custom",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "width": "100%",
                    "max_width": "none",
                    "alignment": "center",
                    "text_color": "#6a6c77"
                  }
                }
              },
              "block_order": ["title", "subtitle"]
            }
          },
          "block_order": ["icon", "text"]
        },
        "col_2": {
