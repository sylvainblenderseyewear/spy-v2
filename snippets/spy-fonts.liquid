<link rel="preload" as="font" type="font/woff" href="{{ 'DINNextLTPro-Regular.woff' | asset_url }}" crossorigin>
<link rel="preload" as="font" type="font/woff" href="{{ 'DINNextLTPro-Bold.woff' | asset_url }}" crossorigin>
<style>
  {%- comment -%} Real DIN Next LT Pro — brand font (Layer 1) {%- endcomment -%}
  @font-face {
    font-family: "DINNextLTPro";
    src: url("{{ 'DINNextLTPro-Light.woff' | asset_url }}") format("woff");
    font-weight: 300;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "DINNextLTPro";
    src: url("{{ 'DINNextLTPro-Regular.woff' | asset_url }}") format("woff");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "DINNextLTPro";
    src: url("{{ 'DINNextLTPro-Bold.woff' | asset_url }}") format("woff");
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  {%- comment -%} D-DIN kept as fallback for any weight DIN Next lacks {%- endcomment -%}
  @font-face {
    font-family: "D-DIN";
    src: url("{{ 'D-DIN.woff2' | asset_url }}") format("woff2");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "D-DIN";
    src: url("{{ 'D-DIN-Bold.woff2' | asset_url }}") format("woff2");
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --font-body--family: "DINNextLTPro", "D-DIN", sans-serif;
    --font-subheading--family: "DINNextLTPro", "D-DIN", sans-serif;
    --font-heading--family: "DINNextLTPro", "D-DIN", sans-serif;
    --font-accent--family: "DINNextLTPro", "D-DIN", sans-serif;
  }

  body {
    font-family: var(--font-body--family);
  }
</style>
